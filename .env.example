# ─────────────────────────────────────────────────────────────────────────────
# Root .env.example – Copy this to .env and fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ───────────────────────────────────────────────────────────────────
# For Railway deployment, use the internal database URL
# For local Docker, use host.docker.internal
# Format: mysql+aiomysql://username:password@host:port/database
# Note: URL-encode special characters in password (# → %23, @ → %40, ! → %21)
DATABASE_URL=mysql+aiomysql://username:password@host:3306/database_name

JWT_SECRET=your_long_random_secret_here_change_this
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=10080
EMAIL_FROM=your@email.com
EMAIL_PASS=your_email_app_password
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587
SITE_URL=https://your-frontend-url.vercel.app
API_BASE_PATH=/api/v1
CORS_ORIGINS=["https://your-frontend-url.vercel.app"]

# ── Frontend (build-time) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://your-backend-url.railway.app/api/v1
